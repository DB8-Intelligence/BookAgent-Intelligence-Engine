# =============================================================================
# BookAgent Worker — Dockerfile (produção Google Cloud Run)
# =============================================================================
# Mesmas correções do Dockerfile (API), mas rodando o worker BullMQ.
# Cloud Run Service com min-instances=1 + no-cpu-throttling (consome fila Redis).
# =============================================================================

FROM node:20-slim AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --no-audit --no-fund

COPY tsconfig.json ./
COPY src ./src
RUN npm run build

RUN npm prune --omit=dev

FROM node:20-slim

ENV NODE_ENV=production \
    PORT=8080

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    poppler-utils \
    python3 \
    fonts-liberation \
    libssl3 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid 1001 bookagent \
    && useradd --system --uid 1001 --gid bookagent --home /app bookagent

WORKDIR /app

COPY --from=builder --chown=bookagent:bookagent /app/package.json ./
COPY --from=builder --chown=bookagent:bookagent /app/node_modules ./node_modules
COPY --from=builder --chown=bookagent:bookagent /app/dist ./dist
COPY --chown=bookagent:bookagent video/ ./video/
COPY --chown=bookagent:bookagent musics/ ./musics/

RUN mkdir -p storage/assets storage/outputs storage/temp \
    && chown -R bookagent:bookagent storage

USER bookagent

# Worker embute um mini HTTP server em worker.ts que expõe GET /health
# para Cloud Run Service health check. Porta via env PORT (default 8080).
EXPOSE 8080

CMD ["node", "dist/worker.js"]
