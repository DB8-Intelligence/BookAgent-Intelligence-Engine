# ============================================================================
# BookAgent Intelligence Engine — Environment Variables
# ============================================================================
# Copie este arquivo para .env e preencha os valores.
#
# Variáveis marcadas com (*) são OBRIGATÓRIAS para produção.
# Sem elas o sistema roda em modo standalone (in-memory, sem IA real).
# ============================================================================

# ============================================================================
# 1. SERVER (*)
# ============================================================================
PORT=3000                                    # (*) Porta do servidor
NODE_ENV=production                          # (*) development | production

# ============================================================================
# 2. CORS
# ============================================================================
# Origens permitidas (separadas por vírgula). Em produção, use o domínio real.
CORS_ORIGIN=https://bookagent.db8intelligence.com.br,https://web-production-73248.up.railway.app

# ============================================================================
# 3. DATABASE — Supabase (*)
# ============================================================================
SUPABASE_URL=https://xhfiyukhjzwhqbacuyxq.supabase.co           # (*) URL do projeto
SUPABASE_SERVICE_ROLE_KEY=eyJ...                                  # (*) Service Role Key (backend only)
# SUPABASE_ANON_KEY=eyJ...                                       # Anon Key (frontend, opcional aqui)

# ============================================================================
# 4. QUEUE — Redis / BullMQ (*)
# ============================================================================
# Sem Redis: processamento síncrono (bloqueante). Com Redis: async + worker.
REDIS_URL=redis://:senha@host:6379                               # (*) Railway / Upstash / managed Redis
# REDIS_HOST=localhost                                           # Alternativa: Docker local
# REDIS_PORT=6379
# REDIS_PASSWORD=sua-senha-redis
QUEUE_CONCURRENCY=2                                              # Jobs em paralelo por worker

# ============================================================================
# 5. AI PROVIDERS (*)
# ============================================================================
# Pelo menos UMA API key é necessária para geração de conteúdo real.
# Sem keys: fallback local (qualidade mínima).

# --- Modo de geração ---
AI_GENERATION_MODE=auto                                          # auto | ai | local
AI_PROVIDER=vertex                                               # (*) vertex (default, GCP) | anthropic | openai | gemini

# --- Roteamento por tarefa (opcional, auto-seleção se omitidos) ---
# AI_BLOG_PROVIDER=openai                                       # GPT-4o para copy de blog/LP
# AI_LANDING_PROVIDER=openai
# AI_MEDIA_PROVIDER=anthropic                                    # Claude para roteiros narrativos
# AI_MULTIMODAL_PROVIDER=vertex                                  # Vertex AI para análise de PDFs pesados

# --- API Keys (pelo menos uma obrigatória) ---
ANTHROPIC_API_KEY=sk-ant-api03-...                               # (*) Anthropic Claude
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=sk-proj-...                                       # OpenAI GPT-4o
# OPENAI_MODEL=gpt-4o-mini

# GEMINI_API_KEY=AIzaSy...                                       # Google Gemini (public API)
# GEMINI_MODEL=gemini-2.0-flash

# --- Vertex AI (Gemini Enterprise) ---
# Auth via Service Account (GOOGLE_APPLICATION_CREDENTIALS=path/to/key.json) ou Workload Identity
# GOOGLE_CLOUD_PROJECT=bookagent-enterprise                      # GCP project ID
# GOOGLE_CLOUD_LOCATION=us-central1                              # Region (us-central1, southamerica-east1, ...)
# VERTEX_AI_MODEL_ID=gemini-2.0-flash-001                        # Fast model (extraction, routing)
# VERTEX_AI_CREATIVE_MODEL=gemini-1.5-pro-002                    # Creative model (storytelling, multimodal PDFs)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # Required for local dev (not on Cloud Run)

# ============================================================================
# 6. TTS — Text-to-Speech
# ============================================================================
TTS_PROVIDER=openai-tts                                          # openai-tts | elevenlabs
TTS_SYNTHESIS_ENABLED=false                                      # true para gerar MP3 real

# ============================================================================
# Video Renderer — FFmpeg local vs Shotstack cloud
# ============================================================================
VIDEO_RENDERER=ffmpeg                                            # ffmpeg (default, no container) | shotstack
# SHOTSTACK_API_KEY=...                                          # Só se VIDEO_RENDERER=shotstack
# SHOTSTACK_ENV=stage                                            # stage | production

# ============================================================================
# Pipeline optimization flags
# ============================================================================
# PIPELINE_PARALLEL_GENERATORS=true                              # Media/Blog/LP em Promise.all (default true)
# PIPELINE_FAST_MODE=false                                       # Skip book-analysis + reverse-engineering (-2-3min, pode reduzir qualidade)
# PIPELINE_USE_GEMINI_ANALYZER=false                             # Chama pdf-analyzer no Ingestion (requer AI_PROVIDER=vertex)
# VISUAL_PARSER_ENABLED=false                                    # Visual Parser per-image (requer AI_PROVIDER=vertex)
# ENHANCED_EXTRACTION=false                                      # Extração de imagens com bbox (mais lento, mais preciso)
# TTS_OPENAI_MODEL=tts-1                                        # tts-1 (rápido) | tts-1-hd
# TTS_VOICE_ID=onyx                                             # alloy, echo, fable, onyx, nova, shimmer

# --- ElevenLabs (alternativa) ---
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# ELEVENLABS_MODEL=eleven_multilingual_v2

# ============================================================================
# 7. STORAGE
# ============================================================================
ASSETS_DIR=storage/assets                                        # Diretório de assets extraídos
OUTPUTS_DIR=storage/outputs                                      # Diretório de outputs gerados
TEMP_DIR=storage/temp                                            # Diretório temporário
MAX_FILE_SIZE_MB=100                                             # Tamanho máximo de arquivo

# ============================================================================
# 8. WHATSAPP — Evolution API
# ============================================================================
EVOLUTION_API_URL=https://evolution-api-production-feed.up.railway.app
EVOLUTION_API_GLOBAL_KEY=sua-global-key
EVOLUTION_INSTANCE=bookagent

# ============================================================================
# 9. SOCIAL PUBLISHING — Meta Graph API
# ============================================================================
# Necessário para publicação automática (plano Pro+)
INSTAGRAM_ACCESS_TOKEN=EAABC...                                  # Token de longa duração
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841234567890                     # ID da conta Business

FACEBOOK_PAGE_ACCESS_TOKEN=EAAB...                               # Token da página
FACEBOOK_PAGE_ID=123456789012345                                 # ID da página

# ============================================================================
# 10. BILLING — Stripe
# ============================================================================
STRIPE_SECRET_KEY=sk_live_...                                    # ou sk_test_... para sandbox
STRIPE_WEBHOOK_SECRET=whsec_...                                  # Secret do webhook endpoint
STRIPE_PRICE_BASIC=price_...                                     # Price ID — Basic R$97
STRIPE_PRICE_PRO=price_...                                       # Price ID — Pro R$247
STRIPE_PRICE_BUSINESS=price_...                                  # Price ID — Business R$997

# ============================================================================
# 11. N8N — Automação / Orquestração
# ============================================================================
N8N_WEBHOOK_BASE_URL=https://automacao.db8intelligence.com.br    # Instância n8n

# ============================================================================
# 12. DASHBOARD / FRONTEND
# ============================================================================
DASHBOARD_URL=https://bookagent.db8intelligence.com.br/dashboard # URL do dashboard (para links WhatsApp)

# ============================================================================
# 13. API SECURITY
# ============================================================================
BOOKAGENT_API_KEY=sua-api-key-secreta                            # Protege endpoints /ops

# ============================================================================
# 14. DEBUG
# ============================================================================
# DEBUG=true                                                     # Ativa logs verbose
