# ============================================================================
# BookAgent Intelligence Engine — Environment Variables
# ============================================================================
# Copie este arquivo para .env e preencha os valores necessários.
#
# IMPORTANTE: Nenhuma variável é obrigatória para rodar o core.
# O sistema funciona 100% sem API keys (usando stubs e lógica local).
# As variáveis abaixo são necessárias apenas quando você quiser
# ativar adapters reais (AI, TTS) ou customizar caminhos.
#
# Documentação completa: docs/PROVIDERS.md
# ============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Storage (caminhos locais, relativos à raiz do projeto) ---
ASSETS_DIR=storage/assets
OUTPUTS_DIR=storage/outputs
TEMP_DIR=storage/temp

# --- Processing ---
MAX_FILE_SIZE_MB=100

# ============================================================================
# AI Providers
# ============================================================================

# --- Modo de geração ---
# auto  → usa IA se API key estiver configurada, fallback local (RECOMENDADO)
# ai    → exige IA, falha se não configurada
# local → sempre usa geração local (ignora providers)
AI_GENERATION_MODE=auto

# --- Provider padrão (fallback quando nenhum específico por tarefa) ---
# anthropic | openai | gemini (default: anthropic)
AI_PROVIDER=anthropic

# --- Roteamento multi-provider por tarefa (OPCIONAL) ---
# Quando configurados, substituem AI_PROVIDER para cada tipo de conteúdo.
# Auto-seleção inteligente quando omitidos (ver docs/PROVIDERS.md).
#
# Recomendação para o ambiente db8-agent (Railway):
#   AI_BLOG_PROVIDER=openai       → GPT-4o para copy de blog/landing
#   AI_LANDING_PROVIDER=openai    → GPT-4o para headlines e seções LP
#   AI_MEDIA_PROVIDER=anthropic   → Claude para roteiros narrativos
#   AI_MULTIMODAL_PROVIDER=gemini → Gemini para análise de imagens/PDFs
#
# AI_BLOG_PROVIDER=openai
# AI_LANDING_PROVIDER=openai
# AI_MEDIA_PROVIDER=anthropic
# AI_MULTIMODAL_PROVIDER=gemini

# --- API Keys ---
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini

# GEMINI_API_KEY=AIzaSy...
# GEMINI_MODEL=gemini-2.0-flash

# ============================================================================
# TTS Providers
# ============================================================================
# Escolha o provider de voz: openai-tts | elevenlabs (default: openai-tts)
TTS_PROVIDER=openai-tts

# Ativar síntese TTS real (gera arquivos MP3 a partir dos AudioPlans)
# false → planos de áudio gerados mas não sintetizados (padrão)
# true  → sintetiza cada segmento em MP3 (requer API key)
TTS_SYNTHESIS_ENABLED=false

# --- OpenAI TTS ---
# Usa a mesma OPENAI_API_KEY configurada acima.
# Modelo: tts-1 (padrão, rápido) | tts-1-hd (alta qualidade)
# TTS_OPENAI_MODEL=tts-1
# TTS_VOICE_ID=onyx
# Vozes disponíveis: alloy, echo, fable, onyx, nova, shimmer

# --- ElevenLabs ---
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# ELEVENLABS_MODEL=eleven_multilingual_v2
# Vozes disponíveis: Adam, Arnold, Antoni, Bella, Rachel, Domi, Elli, Josh

# ============================================================================
# Queue Assíncrona — BullMQ + Redis (Parte 47)
# ============================================================================
# Quando configurado, POST /process retorna imediatamente (não-bloqueante).
# Sem configuração: processamento síncrono (modo legado, totalmente funcional).
#
# Railway Redis: use REDIS_URL com a URL completa (inclui senha e porta)
# Docker local: use REDIS_HOST + REDIS_PORT + REDIS_PASSWORD
#
# REDIS_URL=redis://:senha@host:6379          # Railway / serviços gerenciados
# REDIS_HOST=localhost                         # Docker local
# REDIS_PORT=6379
# REDIS_PASSWORD=sua-senha-redis
#
# Número de jobs processados em paralelo por worker (default: 2)
# QUEUE_CONCURRENCY=2

# ============================================================================
# Supabase (Parte 46 — persistência operacional)
# ============================================================================
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_ANON_KEY=eyJ...

# ============================================================================
# Debug
# ============================================================================
# DEBUG=true
