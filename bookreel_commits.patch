+-- ============================================================================
+-- Migration 008: Webhook Events + User Plans
+-- BookAgent Intelligence Engine
+--
+-- Tabelas para:
+--   1. bookagent_webhook_events — log de eventos recebidos (Hotmart, etc.)
+--   2. bookagent_user_plans     — plano ativo por usuário
+--   3. bookagent_plan_definitions — catálogo de planos
+-- ============================================================================
+
+-- 1. Webhook Events — idempotência e auditoria
+CREATE TABLE IF NOT EXISTS bookagent_webhook_events (
+  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
+  event_type TEXT NOT NULL,
+  source TEXT NOT NULL,           -- transaction_id / event_id externo
+  payload JSONB DEFAULT '{}',
+  processed BOOLEAN DEFAULT FALSE,
+  error TEXT,
+  created_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+CREATE INDEX IF NOT EXISTS idx_webhook_events_source
+  ON bookagent_webhook_events(source);
+CREATE INDEX IF NOT EXISTS idx_webhook_events_type
+  ON bookagent_webhook_events(event_type);
+
+-- 2. User Plans — plano ativo por usuário (email ou phone)
+CREATE TABLE IF NOT EXISTS bookagent_user_plans (
+  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
+  user_id TEXT,                   -- email do comprador
+  phone TEXT,                     -- telefone (WhatsApp)
+  plan TEXT NOT NULL DEFAULT 'free'
+    CHECK (plan IN ('free', 'starter', 'pro', 'agency')),
+  hotmart_sub_id TEXT,            -- subscriber_code do Hotmart
+  status TEXT NOT NULL DEFAULT 'active'
+    CHECK (status IN ('active', 'cancelled', 'expired', 'trial')),
+  books_limit INTEGER NOT NULL DEFAULT 1,
+  books_used INTEGER NOT NULL DEFAULT 0,
+  valid_until TIMESTAMPTZ,
+  created_at TIMESTAMPTZ DEFAULT NOW(),
+  updated_at TIMESTAMPTZ DEFAULT NOW()
+);
+
+-- Unique por user_id (email)
+CREATE UNIQUE INDEX IF NOT EXISTS idx_user_plans_user_id
+  ON bookagent_user_plans(user_id) WHERE user_id IS NOT NULL;
+-- Unique por phone
+CREATE UNIQUE INDEX IF NOT EXISTS idx_user_plans_phone
+  ON bookagent_user_plans(phone) WHERE phone IS NOT NULL;
+
+-- 3. Plan Definitions — catálogo de planos (referência, não enforcement)
+CREATE TABLE IF NOT EXISTS bookagent_plan_definitions (
+  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
+  tier TEXT NOT NULL UNIQUE
