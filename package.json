{
  "name": "bookagent-intelligence-engine",
  "version": "0.2.0",
  "description": "Motor de inteligência documental e geração de conteúdo multimodal para o mercado imobiliário",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "worker:prod": "node dist/worker.js",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "sample": "tsx scripts/sample-run.ts",
    "validate": "tsc --noEmit && vitest run && tsx scripts/sample-run.ts"
  },
  "keywords": [
    "real-estate",
    "content-generation",
    "pdf-extraction",
    "multimodal",
    "intelligence-engine"
  ],
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.1.0",
    "bullmq": "^5.73.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "sharp": "^0.33.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
